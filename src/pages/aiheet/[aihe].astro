---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { topics, getTopic } from '../../data/topics';
import { getAuthor } from '../../data/authors';

export async function getStaticPaths() {
  return topics.map((topic) => ({ params: { aihe: topic.slug } }));
}

const { aihe } = Astro.params;
const topic = getTopic(aihe);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.topic === aihe)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={topic?.label ?? aihe} description={topic?.description}>
  <section class="pt-40 pb-32 px-8">
    <div class="max-w-2xl mx-auto">
      <a href="/aiheet" class="inline-flex items-center gap-2 text-xs tracking-widest uppercase text-muted hover:text-parchment transition-colors mb-16">
        <span>←</span><span>Aiheet</span>
      </a>

      <h1 class="font-serif italic font-light text-4xl md:text-5xl text-parchment mb-4">
        {topic?.label ?? aihe}
      </h1>
      {topic?.description && (
        <p class="text-muted text-sm font-light leading-relaxed max-w-md mb-16">{topic.description}</p>
      )}

      {posts.length === 0 ? (
        <p class="text-muted text-sm font-light">Ei vielä kirjoituksia.</p>
      ) : (
        <div>
          {posts.map((post, i) => {
            const author = getAuthor(post.data.author);
            const formatted = new Intl.DateTimeFormat('fi-FI', {
              day: 'numeric', month: 'long', year: 'numeric',
            }).format(post.data.date);
            return (
              <div>
                {i > 0 && <div class="border-t border-border"></div>}
                <a href={`/kirjoitukset/${post.slug}`} class="group flex items-start justify-between py-7 gap-8">
                  <div class="flex-1 min-w-0">
                    <h2 class="font-serif italic font-light text-xl text-parchment group-hover:opacity-70 transition-opacity leading-snug">
                      {post.data.title}
                    </h2>
                    <p class="text-muted text-xs mt-2 font-light leading-relaxed line-clamp-2">{post.data.description}</p>
                  </div>
                  <div class="flex-shrink-0 text-right">
                    <div class="text-xs text-muted tracking-wide">{author.name}</div>
                    <div class="text-xs text-muted/50 mt-0.5">{formatted}</div>
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
