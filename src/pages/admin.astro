---
export const prerender = false;

import { getCollection } from 'astro:content';
import { topics } from '../data/topics';
import { getAuthor } from '../data/authors';

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 10);

const today = new Date().toISOString().split('T')[0];
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hallinta — Valtava Tutkimus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: #0C0C0B; color: #E8E5DE; font-family: 'Inter', system-ui, sans-serif; font-size: 14px; -webkit-font-smoothing: antialiased; }
      body { min-height: 100vh; }

      /* Layout */
      .topbar { display: flex; align-items: center; justify-content: space-between; padding: 1.5rem 2rem; border-bottom: 1px solid #252420; }
      .topbar-title { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-weight: 300; font-size: 1.125rem; color: #E8E5DE; text-decoration: none; }
      .topbar-right { display: flex; align-items: center; gap: 2rem; }
      .topbar-link { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; text-decoration: none; }
      .topbar-link:hover { color: #E8E5DE; }

      .main { max-width: 720px; margin: 0 auto; padding: 3rem 2rem 6rem; }

      /* Flash messages */
      .flash { font-size: 0.75rem; letter-spacing: 0.05em; padding: 0.75rem 1rem; margin-bottom: 2rem; border: 1px solid; }
      .flash-success { border-color: #252420; color: #6B6860; }
      .flash-error { border-color: #3a2020; color: #8a6060; }

      /* Section header */
      .section-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; margin-bottom: 2rem; }

      /* Form */
      .form { display: flex; flex-direction: column; gap: 1.25rem; }
      label { display: block; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; margin-bottom: 0.4rem; }
      input, select, textarea {
        display: block; width: 100%;
        background: #141413; border: 1px solid #252420;
        color: #E8E5DE; font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.875rem; font-weight: 300;
        padding: 0.75rem 1rem; outline: none;
        appearance: none; -webkit-appearance: none;
      }
      input:focus, select:focus, textarea:focus { border-color: #6B6860; }
      textarea { resize: vertical; line-height: 1.7; min-height: 320px; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .submit-row { display: flex; align-items: center; gap: 2rem; padding-top: 0.5rem; }
      button[type="submit"] {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
        color: #6B6860; background: none; border: none; cursor: pointer; padding: 0;
      }
      button[type="submit"]:hover { color: #E8E5DE; }

      /* Divider */
      .divider { border: none; border-top: 1px solid #252420; margin: 3rem 0; }

      /* Posts list */
      .post-list { display: flex; flex-direction: column; }
      .post-item { display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; padding: 1rem 0; border-bottom: 1px solid #252420; }
      .post-item:first-child { border-top: 1px solid #252420; }
      .post-title { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-weight: 300; font-size: 1.125rem; color: #E8E5DE; text-decoration: none; }
      .post-title:hover { opacity: 0.6; }
      .post-meta { font-size: 0.7rem; color: #6B6860; white-space: nowrap; }

      /* Logout form */
      .logout-btn { font-family: 'Inter', system-ui, sans-serif; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; background: none; border: none; cursor: pointer; }
      .logout-btn:hover { color: #E8E5DE; }
    </style>
  </head>
  <body>

    <header class="topbar">
      <a href="/" class="topbar-title">Valtava Tutkimus</a>
      <div class="topbar-right">
        <a href="/aiheet" class="topbar-link">Aiheet</a>
        <form method="POST" action="/api/logout" style="display:inline">
          <button type="submit" class="logout-btn">Kirjaudu ulos</button>
        </form>
      </div>
    </header>

    <main class="main">

      {success && (
        <div class="flash flash-success">
          Kirjoitus julkaistu. Sivu päivittyy noin 2 minuutissa.
        </div>
      )}
      {error === 'missing' && (
        <div class="flash flash-error">Täytä otsikko ja sisältö.</div>
      )}
      {error === 'github' && (
        <div class="flash flash-error">GitHub-virhe. Tarkista GITHUB_TOKEN.</div>
      )}
      {error === 'notoken' && (
        <div class="flash flash-error">GITHUB_TOKEN puuttuu ympäristömuuttujista.</div>
      )}

      <!-- New post form -->
      <p class="section-label">Uusi kirjoitus</p>

      <form method="POST" action="/api/posts" class="form">
        <div>
          <label for="title">Otsikko</label>
          <input id="title" name="title" type="text" required />
        </div>

        <div>
          <label for="description">Kuvaus</label>
          <input id="description" name="description" type="text" />
        </div>

        <div class="row">
          <div>
            <label for="author">Kirjoittaja</label>
            <select id="author" name="author">
              <option value="julle">Julle</option>
              <option value="tatu">Tatu</option>
            </select>
          </div>
          <div>
            <label for="topic">Aihe</label>
            <select id="topic" name="topic">
              {topics.map((t) => (
                <option value={t.slug}>{t.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div>
          <label for="date">Päivämäärä</label>
          <input id="date" name="date" type="date" value={today} required />
        </div>

        <div>
          <label for="content">Sisältö</label>
          <textarea
            id="content"
            name="content"
            required
            placeholder="Kirjoita tähän. Markdown toimii: **lihavointi**, *kursiivi*, ## Väliotsikko"
          ></textarea>
        </div>

        <div class="submit-row">
          <button type="submit">Julkaise →</button>
        </div>
      </form>

      <hr class="divider" />

      <!-- Recent posts -->
      <p class="section-label">Julkaistut kirjoitukset</p>

      {recentPosts.length === 0 ? (
        <p style="color:#6B6860; font-size:0.875rem; font-weight:300">Ei vielä kirjoituksia.</p>
      ) : (
        <div class="post-list">
          {recentPosts.map((post) => {
            const author = getAuthor(post.data.author);
            const formatted = new Intl.DateTimeFormat('fi-FI', {
              day: 'numeric', month: 'numeric', year: 'numeric',
            }).format(post.data.date);
            return (
              <div class="post-item">
                <a href={`/kirjoitukset/${post.slug}`} class="post-title" target="_blank">
                  {post.data.title}
                </a>
                <span class="post-meta">{author.name} · {formatted}</span>
              </div>
            );
          })}
        </div>
      )}

    </main>
  </body>
</html>
