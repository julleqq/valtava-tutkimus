---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Valtava Tutkimus — Julle & Tatu' } = Astro.props;
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Valtava Tutkimus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400;1,500&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" type="application/rss+xml" title="Valtava Tutkimus" href="/rss.xml" />
  </head>
  <body class="bg-ink text-parchment font-sans min-h-screen flex flex-col">
    <header class="fixed top-0 left-0 right-0 z-50 mix-blend-difference">
      <nav class="flex items-center justify-between px-8 py-6">
        <a href="/" class="font-serif italic text-sm tracking-wide text-parchment hover:opacity-60 transition-opacity">
          Valtava Tutkimus
        </a>
        <div class="flex items-center gap-10">
          <a href="/aiheet" class="text-xs tracking-widest uppercase text-muted hover:text-parchment transition-colors">
            Aiheet
          </a>
          <a href="/kirjoittajat" class="text-xs tracking-widest uppercase text-muted hover:text-parchment transition-colors">
            Kirjoittajat
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border px-8 py-12 mt-24">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <span class="font-serif italic text-muted text-sm">Valtava Tutkimus</span>
        <a href="/rss.xml" class="text-xs tracking-widest uppercase text-muted hover:text-parchment transition-colors">
          RSS
        </a>
      </div>
    </footer>
  </body>
</html>
