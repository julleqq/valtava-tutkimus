---
export const prerender = false;
const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kirjaudu — Valtava Tutkimus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: #0C0C0B; color: #E8E5DE; font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      body { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; }
      .wrap { width: 100%; max-width: 360px; }
      .title { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-weight: 300; font-size: 2rem; color: #E8E5DE; margin-bottom: 2.5rem; }
      label { display: block; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; margin-bottom: 0.5rem; }
      input { display: block; width: 100%; background: #141413; border: 1px solid #252420; color: #E8E5DE; font-family: inherit; font-size: 0.875rem; font-weight: 300; padding: 0.75rem 1rem; outline: none; margin-bottom: 1rem; }
      input:focus { border-color: #6B6860; }
      button { font-family: inherit; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; background: none; border: none; cursor: pointer; padding: 0.75rem 0; margin-top: 0.5rem; }
      button:hover { color: #E8E5DE; }
      .error { font-size: 0.75rem; color: #6B6860; margin-top: 0.75rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <p class="title">Valtava Tutkimus</p>
      <form method="POST" action="/api/login">
        <div>
          <label for="username">Käyttäjätunnus</label>
          <input id="username" name="username" type="text" autocomplete="username" />
        </div>
        <div>
          <label for="password">Salasana</label>
          <input id="password" name="password" type="password" autocomplete="current-password" />
        </div>
        {error && <p class="error">Väärät tunnukset.</p>}
        <button type="submit">Kirjaudu →</button>
      </form>
    </div>
  </body>
</html>
