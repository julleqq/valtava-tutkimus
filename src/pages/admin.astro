---
export const prerender = false;

import { getCollection } from 'astro:content';
import { topics } from '../data/topics';
import { authors, getAuthor } from '../data/authors';

const params = Astro.url.searchParams;
const editSlug = params.get('edit');

interface EditData {
  title: string; description: string; author: string;
  topic: string; date: string; body: string;
}
let editData: EditData | null = null;

if (editSlug && import.meta.env.GITHUB_TOKEN) {
  const res = await fetch(
    `https://api.github.com/repos/julleqq/valtava-tutkimus/contents/src/content/posts/${editSlug}.md`,
    { headers: { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}`, Accept: 'application/vnd.github+json' } }
  );
  if (res.ok) {
    const file = await res.json() as { content: string };
    const raw = Buffer.from(file.content, 'base64').toString('utf-8');
    const match = raw.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n([\s\S]*)$/);
    if (match) {
      const fm = match[1];
      const get = (key: string) =>
        fm.match(new RegExp(`^${key}:\\s*"?(.*?)"?\\s*$`, 'm'))?.[1]?.replace(/\\"/g, '"') ?? '';
      editData = { title: get('title'), description: get('description'), author: get('author'), topic: get('topic'), date: get('date'), body: match[2].trim() };
    }
  }
}

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const today = new Date().toISOString().split('T')[0];
const isEditing = !!(editSlug && editData);
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hallinta — Valtava Tutkimus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: #0C0C0B; color: #E8E5DE; font-family: 'Inter', system-ui, sans-serif; font-size: 14px; -webkit-font-smoothing: antialiased; }
      body { min-height: 100vh; }

      .topbar { display: flex; align-items: center; justify-content: space-between; padding: 1.5rem 2rem; border-bottom: 1px solid #252420; }
      .topbar-title { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 1.125rem; color: #E8E5DE; text-decoration: none; }
      .topbar-right { display: flex; align-items: center; gap: 2rem; }
      .topbar-link { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; text-decoration: none; }
      .topbar-link:hover { color: #E8E5DE; }

      .main { max-width: 720px; margin: 0 auto; padding: 3rem 2rem 6rem; }

      .flash { font-size: 0.75rem; padding: 0.75rem 1rem; margin-bottom: 2rem; border: 1px solid; }
      .flash-ok { border-color: #252420; color: #6B6860; }
      .flash-err { border-color: #3a2020; color: #8a6060; }

      .section-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; margin-bottom: 1.5rem; }
      .section-label a { color: inherit; text-decoration: none; }
      .section-label a:hover { color: #E8E5DE; }
      .divider { border: none; border-top: 1px solid #252420; margin: 3rem 0; }

      /* Forms */
      .form { display: flex; flex-direction: column; gap: 1.25rem; }
      label { display: block; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; margin-bottom: 0.4rem; }
      input, select, textarea {
        display: block; width: 100%;
        background: #141413; border: 1px solid #252420;
        color: #E8E5DE; font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.875rem; font-weight: 300; padding: 0.75rem 1rem;
        outline: none; appearance: none; -webkit-appearance: none;
      }
      input:focus, select:focus, textarea:focus { border-color: #6B6860; }
      textarea { resize: vertical; line-height: 1.7; min-height: 320px; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .btn { font-family: 'Inter', system-ui, sans-serif; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; background: none; border: none; cursor: pointer; padding: 0; }
      .btn:hover { color: #E8E5DE; }
      .btn-danger:hover { color: #c07070; }

      /* Post list */
      .post-list { display: flex; flex-direction: column; }
      .post-item { display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; padding: 1rem 0; border-bottom: 1px solid #252420; }
      .post-item:first-child { border-top: 1px solid #252420; }
      .post-title { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 1.125rem; color: #E8E5DE; text-decoration: none; }
      .post-title:hover { opacity: 0.6; }
      .post-actions { display: flex; align-items: center; gap: 1.5rem; flex-shrink: 0; }
      .post-meta { font-size: 0.7rem; color: #6B6860; }
      .edit-link { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #6B6860; text-decoration: none; }
      .edit-link:hover, .edit-link.active { color: #E8E5DE; }

      /* Topic list */
      .topic-list { display: flex; flex-direction: column; }
      .topic-row { display: flex; align-items: baseline; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #252420; gap: 2rem; }
      .topic-row:first-child { border-top: 1px solid #252420; }
      .topic-name { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 1rem; color: #E8E5DE; }
      .topic-actions { display: flex; align-items: center; gap: 1.25rem; }
      .topic-meta { font-size: 0.7rem; color: #6B6860; }

      /* Collapsible rows */
      details.collapsible { border-bottom: 1px solid #252420; }
      details.collapsible summary { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; cursor: pointer; list-style: none; }
      details.collapsible summary::-webkit-details-marker { display: none; }
      details.collapsible summary .sum-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; }
      details.collapsible summary .sum-arrow { font-size: 0.65rem; color: #6B6860; transition: transform 0.15s; }
      details.collapsible[open] summary .sum-arrow { transform: rotate(90deg); }
      details.collapsible summary:hover .sum-label,
      details.collapsible summary:hover .sum-arrow { color: #E8E5DE; }
      details.collapsible .inner { padding: 1.25rem 0 1.5rem; display: flex; flex-direction: column; gap: 1rem; }

      /* Author cards */
      .author-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      @media (max-width: 560px) { .author-grid { grid-template-columns: 1fr; } }

      /* New-topic inline input */
      #new-topic-row { display: none; margin-top: 0.5rem; }

      .logout-btn { font-family: 'Inter', system-ui, sans-serif; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #6B6860; background: none; border: none; cursor: pointer; }
      .logout-btn:hover { color: #E8E5DE; }
    </style>
  </head>
  <body>

    <header class="topbar">
      <a href="/" class="topbar-title">Valtava Tutkimus</a>
      <div class="topbar-right">
        <a href="/aiheet" class="topbar-link">Aiheet</a>
        <form method="POST" action="/api/logout" style="display:inline">
          <button type="submit" class="logout-btn">Kirjaudu ulos</button>
        </form>
      </div>
    </header>

    <main class="main">

      <!-- Flash messages -->
      {params.get('success') && <div class="flash flash-ok">Kirjoitus julkaistu. Sivu päivittyy noin 2 minuutissa.</div>}
      {params.get('deleted') && <div class="flash flash-ok">Kirjoitus poistettu. Sivu päivittyy noin 2 minuutissa.</div>}
      {params.get('topic-success') && <div class="flash flash-ok">Aihe lisätty. Sivu päivittyy noin 2 minuutissa.</div>}
      {params.get('topic-deleted') && <div class="flash flash-ok">Aihe poistettu. Kirjoitukset siirtyvät "Muut aiheet" -osioon.</div>}
      {params.get('author-updated') && <div class="flash flash-ok">Kirjoittajan tiedot päivitetty. Sivu päivittyy noin 2 minuutissa.</div>}
      {params.get('error') === 'missing' && <div class="flash flash-err">Täytä otsikko ja sisältö.</div>}
      {params.get('error') === 'missing-topic' && <div class="flash flash-err">Täytä aiheen nimi.</div>}
      {params.get('error') === 'topic-exists' && <div class="flash flash-err">Samanniminen aihe on jo olemassa.</div>}
      {params.get('error') === 'github' && <div class="flash flash-err">GitHub-virhe. Tarkista GITHUB_TOKEN.</div>}
      {params.get('error') === 'notoken' && <div class="flash flash-err">GITHUB_TOKEN puuttuu ympäristömuuttujista.</div>}

      <!-- ── Post editor ── -->
      <div class="section-label">
        {isEditing
          ? <><a href="/admin">← Uusi kirjoitus</a> &nbsp;·&nbsp; Muokkaa</>
          : 'Uusi kirjoitus'
        }
      </div>

      <form method="POST" action="/api/posts" class="form">
        {isEditing && <input type="hidden" name="slug" value={editSlug} />}

        <div>
          <label for="title">Otsikko</label>
          <input id="title" name="title" type="text" required value={editData?.title ?? ''} />
        </div>

        <div>
          <label for="description">Kuvaus</label>
          <input id="description" name="description" type="text" value={editData?.description ?? ''} />
        </div>

        <div class="row">
          <div>
            <label for="author">Kirjoittaja</label>
            <select id="author" name="author">
              {authors.map((a) => (
                <option value={a.slug} selected={editData?.author === a.slug}>{a.name}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="topic">Aihe</label>
            <select id="topic" name="topic" onchange="handleTopicChange(this)">
              {topics.map((t) => (
                <option value={t.slug} selected={editData?.topic === t.slug}>{t.label}</option>
              ))}
              <option value="__new__">+ Uusi aihe</option>
            </select>
            <div id="new-topic-row">
              <input id="new-topic-label" name="new-topic-label" type="text" placeholder="Aiheen nimi" />
            </div>
          </div>
        </div>

        <div>
          <label for="date">Päivämäärä</label>
          <input id="date" name="date" type="date" value={editData?.date ?? today} required />
        </div>

        <div>
          <label for="content">Sisältö</label>
          <textarea id="content" name="content" required>{editData?.body ?? ''}</textarea>
        </div>

        <div>
          <button type="submit" class="btn">{isEditing ? 'Päivitä →' : 'Julkaise →'}</button>
        </div>
      </form>

      <hr class="divider" />

      <!-- ── Published posts ── -->
      <p class="section-label">Julkaistut kirjoitukset</p>

      {sortedPosts.length === 0 ? (
        <p style="color:#6B6860; font-weight:300">Ei vielä kirjoituksia.</p>
      ) : (
        <div class="post-list">
          {sortedPosts.map((post) => {
            const author = getAuthor(post.data.author);
            const formatted = new Intl.DateTimeFormat('fi-FI', { day: 'numeric', month: 'numeric', year: 'numeric' }).format(post.data.date);
            return (
              <div class="post-item">
                <a href={`/kirjoitukset/${post.slug}`} class="post-title" target="_blank">{post.data.title}</a>
                <div class="post-actions">
                  <span class="post-meta">{author.name} · {formatted}</span>
                  <a href={`/admin?edit=${post.slug}`} class={`edit-link${editSlug === post.slug ? ' active' : ''}`}>Muokkaa</a>
                  <form method="POST" action="/api/delete-post" style="display:inline">
                    <input type="hidden" name="slug" value={post.slug} />
                    <button type="submit" class="btn btn-danger" onclick={`return confirm('Poistetaanko "${post.data.title}"?')`}>Poista</button>
                  </form>
                </div>
              </div>
            );
          })}
        </div>
      )}

      <hr class="divider" />

      <!-- ── Topics ── -->
      <p class="section-label">Aiheet</p>

      <div class="topic-list">
        {topics.map((t) => {
          const count = allPosts.filter((p) => p.data.topic === t.slug).length;
          return (
            <div class="topic-row">
              <span class="topic-name">{t.label}</span>
              <div class="topic-actions">
                <span class="topic-meta">{count} kirjoitusta</span>
                <form method="POST" action="/api/delete-topic" style="display:inline">
                  <input type="hidden" name="slug" value={t.slug} />
                  <button type="submit" class="btn btn-danger" onclick={`return confirm('Poistetaanko aihe "${t.label}"? Kirjoitukset siirtyvät Muut aiheet -osioon.')`}>Poista</button>
                </form>
              </div>
            </div>
          );
        })}

        <details class="collapsible">
          <summary>
            <span class="sum-label">Uusi aihe</span>
            <span class="sum-arrow">›</span>
          </summary>
          <form method="POST" action="/api/topics" class="inner">
            <div>
              <label for="topic-label">Nimi</label>
              <input id="topic-label" name="label" type="text" placeholder="esim. Ekologia" />
            </div>
            <div>
              <label for="topic-desc">Kuvaus</label>
              <input id="topic-desc" name="description" type="text" placeholder="Lyhyt kuvaus aiheesta." />
            </div>
            <button type="submit" class="btn">Lisää →</button>
          </form>
        </details>
      </div>

      <hr class="divider" />

      <!-- ── Authors ── -->
      <p class="section-label">Kirjoittajat</p>

      <div class="author-grid">
        {authors.map((a) => (
          <form method="POST" action="/api/update-author" class="form">
            <input type="hidden" name="slug" value={a.slug} />
            <div>
              <label>Nimi</label>
              <input name="name" type="text" value={a.name} required />
            </div>
            <div>
              <label>Bio</label>
              <textarea name="bio" rows={3} style="min-height:0">{a.bio}</textarea>
            </div>
            <button type="submit" class="btn">Tallenna →</button>
          </form>
        ))}
      </div>

    </main>

    <script>
      function handleTopicChange(select: HTMLSelectElement) {
        const row = document.getElementById('new-topic-row') as HTMLDivElement;
        const input = document.getElementById('new-topic-label') as HTMLInputElement;
        const show = select.value === '__new__';
        row.style.display = show ? 'block' : 'none';
        input.required = show;
        if (show) input.focus();
      }
    </script>

  </body>
</html>
